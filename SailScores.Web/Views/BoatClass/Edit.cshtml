@model SailScores.Web.Models.SailScores.BoatClassWithHandicapsViewModel

@{
    ViewData["Title"] = "Edit Class";
    Layout = "~/Views/Shared/_ClubLayout.cshtml";
}

<h2>Edit class</h2>

<hr />
<div class="row">
    <div class="col-md-6 col-lg-4">
        <form asp-action="Edit">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ClubId" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="control-label"></label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-controller="Admin"
                   asp-action="Index"
                   asp-fragment="classes"
                   class="btn btn-outline-primary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@if (Model.HandicapRatings != null)
{
    <hr />
    <div class="row">
        <div class="col-12 col-xl-8">
            <h4>Handicap Ratings</h4>
            @if (Model.HandicapRatings.Any())
            {
                <table class="table table-sm table-striped">
                    <thead>
                        <tr>
                            <th>System</th>
                            <th>Rating</th>
                            <th>From</th>
                            <th>To</th>
                            <th>Notes</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var h in Model.HandicapRatings)
                        {
                            <tr>
                                <td>@(h.HandicapSystem?.Name ?? h.HandicapSystemId.ToString("D").Substring(0, 8))</td>
                                <td>@h.Value</td>
                                <td>@(h.EffectiveFrom?.ToString("d") ?? "—")</td>
                                <td>@(h.EffectiveTo?.ToString("d") ?? "—")</td>
                                <td>@h.Notes</td>
                                <td>
                                    <a asp-action="EditHandicapEntry"
                                       asp-route-boatClassId="@Model.Id"
                                       asp-route-handicapId="@h.Id"
                                       class="btn btn-sm btn-outline-secondary">Edit</a>
                                    <form asp-action="DeleteHandicap" method="post" style="display:inline;"
                                          onsubmit="return confirm('Delete this handicap rating?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="handicapId" value="@h.Id" />
                                        <input type="hidden" name="boatClassId" value="@Model.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted">No handicap ratings on file.</p>
            }
            <a asp-action="AddHandicap"
               asp-route-boatClassId="@Model.Id"
               class="btn btn-sm btn-outline-primary mb-3">Add Handicap Rating</a>
        </div>
    </div>
}

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
