@using SailScores.Web.Services
@using SailScores.Api.Enumerations

@model SailScores.Web.Models.SailScores.SeriesWithOptionsViewModel

@{
    ViewData["Title"] = "Edit";
    Layout = "~/Views/Shared/_ClubLayout.cshtml";
}

<h3>Edit Series Properties</h3>
<hr />
<div class="row">
    <div class="col-lg-6 col-md-8">
        <form asp-action="Edit"
              asp-route-returnurl="@ViewData["ReturnUrl"]" >
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ClubId" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="control-label"></label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div id="seasonSelectGroup" class="mb-3">
                <label asp-for="SeasonId" class="control-label">Season</label>
                <select asp-for="SeasonId" class="form-select" disabled>
                    <option selected="selected">Select a season...</option>
                    @foreach (var season in Model.SeasonOptions)
                    {
                        <option value="@season.Id">
                            @season.Name
                        </option>
                    }
                </select>
                <span asp-validation-for="SeasonId" class="text-danger"></span>
            </div>

            <div id="advancedFields" role="tablist">
                <div class="card">
                    <div class="card-header" role="tab" id="advancedHeading">
                        <h5 class="mb-0">
                            <a class="collapsed" data-bs-toggle="collapse" href="#collapseAdvanced" aria-expanded="false" aria-controls="collapseAdvanced">
                                Additional Settings <span class="fas fa-chevron-down"></span></a>
                                <span class="small"><em>&ensp;Optional</em></span>
                        </h5>
                    </div>

                    <div id="collapseAdvanced" class="collapse" role="tabpanel" aria-labelledby="advancedHeading" data-parent="#advancedFields">
                        <div class="card-body">

                            <!-- Appearance -->
                            <div class="settings-section mb-4">
                                <h4 class="mb-3">Appearance</h4>
                                <div class="row g-3">
                                    <div class="col-12 col-md-6 settings-group">
                                        <div class="form-check">
                                            <input class="form-check-input" asp-for="IsImportantSeries" />
                                            <label class="form-check-label">List as Top Series</label>
                                        </div>
                                    </div>
                                    <div class="col-12 col-md-6 settings-group">
                                        <label asp-for="TrendOption">Show Rank Trend</label>
                                        <select asp-for="TrendOption" class="form-select">
                                            @foreach (var trendOption in EnumHelper<TrendOption>.GetValues(TrendOption.None))
                                            {
                                                <option value="@trendOption">
                                                    @(EnumHelper<TrendOption>.GetDisplayValue(trendOption))
                                                </option>
                                            }
                                        </select>
                                        <span asp-validation-for="TrendOption" class="text-danger"></span>
                                    </div>
                                    @if (Model.TemplateOptions != null && Model.TemplateOptions.Any())
                                    {
                                        <div class="col-12 col-md-6 settings-group">
                                            <label asp-for="SeriesResultsTemplateId" class="control-label">
                                                View Template
                                                <a class="text-primary"
                                                   data-bs-container="body"
                                                   data-bs-toggle="popover"
                                                   data-bs-placement="top"
                                                   data-bs-trigger="focus hover"
                                                   data-bs-content="Choose a template that controls which columns appear in the series results table and their visibility on different screen sizes.">
                                                    <span class="far fa-question-circle"></span>
                                                </a>
                                            </label>
                                            <select asp-for="SeriesResultsTemplateId" class="form-select">
                                                <option value="">-Use club default-</option>
                                                @foreach (var template in Model.TemplateOptions)
                                                {
                                                    <option value="@template.Id">@template.Name</option>
                                                }
                                            </select>
                                            <span asp-validation-for="SeriesResultsTemplateId" class="text-danger"></span>
                                            <small class="form-text text-muted">Create templates in the Club Info page.</small>
                                        </div>
                                    }
                                </div>
                            </div>

                            <!-- Date Restrictions -->
                            @if (Model.Type == SailScores.Core.Model.SeriesType.Unknown ||
                              Model.Type == SailScores.Core.Model.SeriesType.Standard ||
                              Model.Type == SailScores.Core.Model.SeriesType.Regatta)
                            {
                                <div class="settings-section mb-4">
                                    <h4 class="mb-3">Date Restrictions</h4>
                                    <div class="row g-3">
                                        <div class="col-12 settings-group">
                                            <div class="form-check">
                                                <input type="checkbox" class="form-check-input" id="DateRestricted" name="DateRestricted" value="true" @(Model.DateRestricted == true ? "checked" : "") />
                                                <label class="form-check-label" for="DateRestricted">Restrict Series Dates</label>
                                                <small class="form-text text-muted d-block">Limit when this series appears in race creation/editing.</small>
                                            </div>
                                        </div>
                                        <div id="dateRestrictionFields" class="col-12" style="display: @(Model.DateRestricted == true ? "block" : "none");">
                                            <div class="row g-3">
                                                <div class="col-12 col-md-6 settings-group">
                                                    <label asp-for="EnforcedStartDate" class="control-label">Start Date</label>
                                                    <input asp-for="EnforcedStartDate" type="date" class="form-control" />
                                                    <span asp-validation-for="EnforcedStartDate" class="text-danger"></span>
                                                </div>
                                                <div class="col-12 col-md-6 settings-group">
                                                    <label asp-for="EnforcedEndDate" class="control-label">End Date</label>
                                                    <input asp-for="EnforcedEndDate" type="date" class="form-control" />
                                                    <span asp-validation-for="EnforcedEndDate" class="text-danger"></span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }

                            <!-- Scoring -->
                            <div class="settings-section mb-4">
                                <h4 class="mb-3">Scoring</h4>
                                <div class="row g-3">
                                    @if (Model.SummarySeriesOptions != null && Model.SummarySeriesOptions.Any() &&
                                      Model.Type == SailScores.Core.Model.SeriesType.Standard)
                                    {
                                        <div class="col-12 settings-group">
                                            <label asp-for="ParentSeriesIds" class="control-label">Include in Summary Series</label>
                                            <select id="ParentSeriesIds" asp-for="ParentSeriesIds" class="form-select" multiple>
                                                @foreach (var series in Model.SummarySeriesOptions)
                                                {
                                                    <option value="@series.Id">
                                                        @series.Name (@series.Season.Name)
                                                    </option>
                                                }
                                            </select>
                                            <span asp-validation-for="ParentSeriesIds" class="text-danger"></span>
                                            <span class="small">Select one or more summary series that this series should be included in.</span>
                                        </div>
                                    }
                                    <div class="col-12 col-md-6 settings-group">
                                        <label asp-for="ScoringSystemId">Scoring System</label>
                                        <select id="ScoringSystemId" asp-for="ScoringSystemId" class="form-select">
                                            @foreach (var scoringSystem in Model.ScoringSystemOptions)
                                            {
                                                <option value="@scoringSystem.Id">
                                                    @scoringSystem.Name
                                                </option>
                                            }
                                        </select>
                                        <span asp-validation-for="ScoringSystemId" class="text-danger"></span>
                                    </div>
                                    @if (Model.HandicapSystemOptions != null && Model.HandicapSystemOptions.Any())
                                    {
                                        <div class="col-12 col-md-6 settings-group">
                                            <label asp-for="HandicapSystemId">Handicap System</label>
                                            <select asp-for="HandicapSystemId" class="form-select">
                                                @foreach (var hs in Model.HandicapSystemOptions)
                                                {
                                                    <option value="@hs.Id">@hs.Name</option>
                                                }
                                            </select>
                                            <span asp-validation-for="HandicapSystemId" class="text-danger"></span>
                                            <small class="form-text text-muted">Select a handicap system to enable corrected-time scoring for this series.</small>
                                        </div>
                                    }
                                    <div class="col-12 col-md-6 settings-group">
                                        <div class="form-check">
                                            <input class="form-check-input" asp-for="ResultsLocked" />
                                            <label>Lock Results</label>
                                            <small class="form-text text-muted d-block">Prevents scores from recalculating for this series</small>
                                        </div>
                                    </div>
                                    <div class="col-12 col-md-6 settings-group">
                                        <div class="form-check">
                                            <input class="form-check-input" asp-for="HideDncDiscards" />
                                            <label class="form-check-label">Hide Discarded DNC Scores</label>
                                            <small class="form-text text-muted d-block">Show as blanks</small>
                                        </div>
                                    </div>
                                    <div class="col-12 col-md-6 settings-group">
                                        <div class="form-check">
                                            <input class="form-check-input" asp-for="ExcludeFromCompetitorStats" />
                                            <label class="form-check-label">Exclude from Competitor Statistics</label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Fleet -->
                            <div class="settings-section mb-4">
                                <h4 class="mb-3">Fleet</h4>
                                <div class="row g-3">
                                    <div class="col-12 settings-group">
                                        <label asp-for="FleetId" class="control-label">
                                            Fleet Competitor Filter
                                            <a class="text-primary"
                                               data-bs-container="body"
                                               data-bs-toggle="popover"
                                               data-bs-placement="top"
                                               data-bs-trigger="focus hover"
                                               data-bs-content="Limit series results to include only competitors of a specific fleet. E.g., create a Women's Series from races that include all sailors. (Race could be assigned to multiple series.)">
                                                <span class="far fa-question-circle"></span>
                                            </a>
                                        </label>
                                        <select id="FleetId" asp-for="FleetId" class="form-select">
                                            <option value="">-Allow any competitors-</option>
                                            @if (Model.FleetOptions != null)
                                            {
                                                @foreach (var fleet in Model.FleetOptions)
                                                {
                                                    <option value="@fleet.Id">
                                                        @fleet.Name @(fleet.IsActive ? "" : " (Inactive)")
                                                    </option>
                                                }
                                            }
                                        </select>
                                        <span asp-validation-for="FleetId" class="text-danger"></span>
                                        <span class="small">Only competitors in this fleet will appear in series standings.</span>
                                    </div>
                                    <div id="useFullRaceScoresField" class="col-12 settings-group" style="display: @(Model.FleetId.HasValue && Model.FleetId != Guid.Empty ? "block" : "none"); margin-left: 2rem;">
                                        <div class="form-check">
                                            <input type="checkbox" class="form-check-input" id="UseFullRaceScores" name="UseFullRaceScores" value="true" @(Model.UseFullRaceScores == true ? "checked" : "") />
                                            <input type="hidden" name="UseFullRaceScores" value="false" />
                                            <label class="form-check-label" for="UseFullRaceScores">
                                                Use Original Race Positions
                                                <a class="text-primary"
                                                       data-bs-container="body"
                                                       data-bs-toggle="popover"
                                                       data-bs-placement="top"
                                                       data-bs-trigger="focus hover"
                                                       data-bs-content="Unchecked (default): Rank competitors only against others in the fleet. Checked: Use original race ranking even if non-fleet competitors placed higher.">
                                                    <span class="far fa-question-circle"></span>
                                                </a>
                                            </label>
                                            <small class="form-text text-muted d-block">Finishing positions include all race competitors if selected.</small>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Advanced Tools -->
                            <div class="settings-section mb-4">
                                <h4 class="mb-3">Advanced Tools</h4>
                                <div class="row g-3">
                                    <div class="col-12 col-md-6 settings-group">
                                        <label>Scoring "What‑If"</label>
                                        <a class="form-control btn btn-secondary"
                                           asp-route="WhatIf"
                                           asp-route-action="options"
                                           asp-route-seriesId="@Model.Id"
                                           asp-route-clubInitials="@ViewContext.RouteData.Values["ClubInitials"]"
                                           asp-route-returnUrl="@ViewData["ReturnUrl"]"
                                           title="Test scoring changes">Try Different Scoring</a>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
            <br />
            <div class="mb-3">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a href="@(ViewData["ReturnUrl"] ?? Url.Action("Index", "Admin"))"
                   class="btn btn-outline-primary">Cancel</a>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="~/js/seriesDateRestriction.js"></script>
    <script>
        function toggleUseFullRaceScores() {
            var fleetIdSelect = document.getElementById('FleetId');
            var useFullRaceScoresField = document.getElementById('useFullRaceScoresField');
            if (fleetIdSelect.value) {
                useFullRaceScoresField.style.display = 'block';
            } else {
                useFullRaceScoresField.style.display = 'none';
            }
        }

        document.getElementById('FleetId').addEventListener('change', toggleUseFullRaceScores);

        // help popovers (to be touch screen friendly.)
        $(function () {
            $('[data-bs-toggle="popover"]').popover();
        })

        var dateRestrictedCheckbox = document.getElementById('DateRestricted');
        if (dateRestrictedCheckbox) {
            dateRestrictedCheckbox.addEventListener('change', toggleDateRestrictionFields);
            // Run on page load in case of validation errors
            toggleDateRestrictionFields();
        }
    </script>
}
