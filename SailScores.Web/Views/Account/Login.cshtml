@using Microsoft.AspNetCore.Identity
@using SailScores.Identity.Entities
@model SailScores.Web.Models.AccountViewModels.LoginViewModel
@inject SignInManager<ApplicationUser> SignInManager

@{
    ViewData["Title"] = "Log in";
    var loginProviders = (await SignInManager.GetExternalAuthenticationSchemesAsync()).ToList();
}

@section AdditionalMeta
{
    <meta name="robots" content="noindex,nofollow" />
}
<h2>@ViewData["Title"]</h2>
<div class="row">
    <div class="col-md-6 col-xl-4">
        <section>
            <form asp-route-returnurl="@ViewData["ReturnUrl"]" method="post">
                <h4>Use a SailScores account to log in.</h4>
                <hr />
                <div asp-validation-summary="All" class="text-danger"></div>
                <div class="mb-3">
                    <label asp-for="Email"></label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Password"></label>
                    <input asp-for="Password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <div class="checkbox">
                        <label asp-for="RememberMe">
                            <input asp-for="RememberMe" />
                            @Html.DisplayNameFor(m => m.RememberMe)
                        </label>
                    </div>
                </div>
                <div class="mb-3">
                    <button type="submit" class="btn btn-primary">Log in</button>
                </div>
                <div class="mb-3">
                    <p>
                        <a asp-action="ForgotPassword">Forgot your password?</a>
                    </p>
                    <p>
                        <a asp-action="Register" asp-route-returnurl="@ViewData["ReturnUrl"]">Register as a new user?</a>
                    </p>
                </div>
            </form>
        </section>
    </div>
    @if (loginProviders.Count > 0)
    {
        <div class="col-md-5 col-md-offset-1">
            <section>
                <h4>Or sign in with</h4>
                <hr />
                <form asp-action="ExternalLogin" asp-route-returnurl="@ViewData["ReturnUrl"]" method="post">
                    <div class="d-flex flex-column gap-2" style="max-width:280px;">
                        @foreach (var provider in loginProviders)
                        {
                            @switch (provider.Name)
                            {
                                case "Google":
                                    <button type="submit" name="provider" value="Google"
                                            class="btn w-100 fw-semibold"
                                            style="background-color:#4285F4;color:#fff;border-color:#4285F4;"
                                            title="Sign in with your Google account">
                                        <i class="fab fa-google me-2"></i>Sign in with Google
                                    </button>
                                    break;

                                case "Microsoft":
                                case "MicrosoftAccount":
                                    <button type="submit" name="provider" value="@provider.Name"
                                            class="btn w-100 fw-semibold"
                                            style="background-color:#2F2F2F;color:#fff;border-color:#2F2F2F;"
                                            title="Sign in with your Microsoft account">
                                        <i class="fab fa-microsoft me-2"></i>Sign in with Microsoft
                                    </button>
                                    break;

                                case "Apple":
                                    <button type="submit" name="provider" value="Apple"
                                            class="btn btn-dark w-100 fw-semibold"
                                            title="Sign in with your Apple ID">
                                        <i class="fab fa-apple me-2"></i>Sign in with Apple
                                    </button>
                                    break;

                                case "Facebook":
                                    <button type="submit" name="provider" value="Facebook"
                                            class="btn w-100 fw-semibold"
                                            style="background-color:#1877F2;color:#fff;border-color:#1877F2;"
                                            title="Sign in with your Facebook account">
                                        <i class="fab fa-facebook me-2"></i>Sign in with Facebook
                                    </button>
                                    break;

                                default:
                                    <button type="submit" name="provider" value="@provider.Name"
                                            class="btn btn-secondary w-100"
                                            title="Sign in using your @provider.DisplayName account">
                                        @provider.DisplayName
                                    </button>
                                    break;
                            }
                        }
                    </div>
                </form>
            </section>
        </div>
    }
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
