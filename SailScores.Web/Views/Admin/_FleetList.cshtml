@model IEnumerable<SailScores.Web.Models.SailScores.FleetDeleteViewModel>
<div id="fleetsdiv">
    <div class="row">
        <div class="col-2 col-sm-4 col-md-3">
            <a class="btn btn-primary"
                asp-action="Create"
                asp-controller="Fleet">
                <span class="fas fa-plus"></span>
                <span class="d-none d-sm-inline">
                    New Fleet
                </span>
            </a>
        </div>
        <div class="col-12 col-md-4 d-flex align-items-center justify-content-md-end mt-2 mt-md-0">
          <div class="form-check d-flex align-items-center">
            <input id="admin-show-inactive" class="form-check-input" type="checkbox" /> <label for="admin-show-inactive" class="form-check-label ms-2 mb-0">Show Inactive</label>
          </div>
        </div>
    </div>
    @foreach (var item in Model.OrderBy(f => f.Name))
    {
        var inactiveClass = item.IsActive ? "" : " fleet-inactive d-none";
        <div class="row border-bottom mt-1 mb-1 pt-1 pb-1 ms-md-2@(inactiveClass)">
            <div class="col-12 col-sm-6 col-md-6">

                @if(!item.IsDeletable)
				{
                    <span data-bs-toggle="tooltip" title="Cannot be deleted: @item.PreventDeleteReason">
					<button class="btn btn-sm btn-outline-danger disabled"
				       disabled="disabled"
                        type="button">
			         <span class="fas fa-trash"></span>
			        </button>
                    </span>
				} else {
				    <a class="btn btn-sm btn-outline-danger"
				       asp-action="Delete"
				       asp-controller="Fleet"
				       asp-route-id="@item.Id"
					    title = "Delete">
			        <span class="fas fa-trash"></span>
			        </a>
				}&nbsp;
                <a class="btn btn-sm btn-outline-primary"
                    asp-action="Edit"
                    asp-controller="Fleet"
                    asp-route-id="@item.Id"
                    title="Edit">
                    <span class="fas fa-pen"></span>
                </a> &nbsp;
                @Html.DisplayFor(modelItem => item.Name)
            </div>
            <div class="col-12 col-sm-6 col-md-3">
                @Html.DisplayFor(modelItem => item.FleetType)
            </div>
            <div class="col-12 col-sm-6 col-md-3">
                @Html.DisplayFor(modelItem => item.Description)
                <em class="text-muted">@(item.IsRegattaFleet ? "Regatta fleet" : "")</em>
                <em class="text-warning">@(item.IsActive ? "" : "Inactive")</em>
            </div>
        </div>
    }
</div>

<script>
    function initFleetInactiveToggle() {
        var checkbox = document.getElementById('admin-show-inactive');
        if (!checkbox) return;

        // Remove any existing listener to avoid duplicates
        checkbox.removeEventListener('change', toggleInactiveFleets);

        // default unchecked - inactive rows are hidden by d-none on load
        checkbox.addEventListener('change', toggleInactiveFleets);
    }

    function toggleInactiveFleets() {
        var checkbox = document.getElementById('admin-show-inactive');
        var inactiveRows = document.querySelectorAll('#fleetsdiv .fleet-inactive');
        inactiveRows.forEach(function(r) {
            if (checkbox.checked) {
                r.classList.remove('d-none');
            } else {
                r.classList.add('d-none');
            }
        });
    }

    // Initialize on DOMContentLoaded
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initFleetInactiveToggle);
    } else {
        initFleetInactiveToggle();
    }
</script>
