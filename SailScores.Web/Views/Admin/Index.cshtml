@using Microsoft.Extensions.Localization
@using SailScores.Web.Resources

@inject IStringLocalizer<SharedResource> localizer

@model SailScores.Web.Models.SailScores.AdminViewModel

@{
    ViewData["Title"] = "Admin " + Model.Name;
    Layout = "_ClubLayout";
}

<style>
    /* Remove borders on accordion items in the admin page */
    #adminAccordion .accordion-item {
        border: 0 !important;
        box-shadow: none !important;
    }

    /* Make accordion headers look like links but underline only the title text */
    #adminAccordion .accordion-button {
        box-shadow: none !important;
        background: transparent !important;
        color: var(--bs-link-color) !important;
        text-decoration: none !important; /* don't underline whole button */
        padding: .5rem 1rem !important;
        font-weight: 500 !important;
        cursor: pointer !important;
        display: flex !important;
        align-items: center !important;
    }

        /* Underline only the title text so whitespace and icons are not underlined */
        #adminAccordion .accordion-button .accordion-title {
            text-decoration: underline !important;
            display: inline !important;
            color: inherit !important;
        }

        /* Use emphasized color when expanded but keep the same font weight */
        #adminAccordion .accordion-button:not(.collapsed) {
            /* keep button un-underlined; do not change weight */
            text-decoration: none !important;
            color: var(--bs-primary-text-emphasis) !important;
        }

            /* Remove underline from the title when expanded and use emphasized color without bolding */
            #adminAccordion .accordion-button:not(.collapsed) .accordion-title {
                text-decoration: none !important;
                font-weight: 500 !important;
                color: var(--bs-primary-text-emphasis) !important;
            }

        /* Prevent the help icon from inheriting underline and match link text color */
        #adminAccordion .accordion-button .accordion-help-icon {
            text-decoration: none !important;
            margin-left: .5rem;
            color: var(--bs-link-color) !important;
            display: inline-block;
        }

        /* Keep the collapse chevron visible but subtle and move it left of the title */
        #adminAccordion .accordion-button::after {
            opacity: .85;
            /* place the pseudo before the button content */
            order: -1;
            margin-left: 0;
            margin-right: .75rem; /* space between chevron and title */
            transform: rotate(-90deg) !important;
            transition: transform 0.35s ease !important;
        }

        /* Rotate 90 degrees when expanded (pointing down) */
        #adminAccordion .accordion-button:not(.collapsed)::after {
            transform: rotate(0deg) !important;
        }

    /* Slightly increase left padding so the chevron isn't flush to the edge */
    #adminAccordion .accordion-button {
        padding-left: 1rem !important;
    }

    /* Side navigation for xxl+ screens */
    .admin-side-nav {
        padding-top: 1rem;
        padding-right: 1rem;
        border-right: 1px solid rgba(0,0,0,0.06);
        /* run along the side from the top of the viewport */
        position: sticky;
        height: 80vh;
        overflow-y: auto;
    }

        .admin-side-nav .nav-link {
            color: var(--bs-link-color) !important;
            padding: .25rem 0 !important;
            display: block;
        }

            .admin-side-nav .nav-link:hover,
            .admin-side-nav .nav-link:focus,
            .admin-side-nav .nav-link.active {
                color: var(--bs-primary-text-emphasis) !important;
                text-decoration: none !important;
            }

        /* Keep the inner wrapper static when the nav itself is sticky */
        .admin-side-nav .sticky-offset {
            position: static;
        }
</style>

<div class="row">
    <aside class="col-2 d-none d-xxl-block">
        <nav class="admin-side-nav">
            <div class="sticky-offset">
                <ul class="nav flex-column">
                    @if (Model.IsClubAdmin)
                    {
                        <li class="nav-item"><a class="nav-link accordion-nav" href="#collapseClasses">Classes</a></li>
                        <li class="nav-item"><a class="nav-link accordion-nav" href="#collapseFleets">Fleets</a></li>
                        <li class="nav-item"><a class="nav-link accordion-nav" href="#collapseSeasons">Seasons</a></li>
                    }

                    @if (Model.CanEditSeries)
                    {
                        <li class="nav-item"><a class="nav-link accordion-nav" href="#collapseSeries">Series</a></li>
                    }

                    <li class="nav-item"><a class="nav-link accordion-nav" href="#collapseCompetitors">Competitors</a></li>
                    <li class="nav-item"><a class="nav-link accordion-nav" href="#collapseRaces">Races</a></li>

                    @if (Model.IsClubAdmin)
                    {
                        <li class="nav-item"><a class="nav-link accordion-nav" href="#collapseScoring">Scoring Systems</a></li>
                        <li class="nav-item"><a class="nav-link accordion-nav" href="#collapseRegattas">Regattas</a></li>
                        <li class="nav-item"><a class="nav-link accordion-nav" href="#collapseScorekeepers">Scorekeepers</a></li>
                    }
                </ul>
            </div>
        </nav>
    </aside>

    <main class="col-12 col-xxl-10">

<h2>@Model.Name Admin</h2>
<hr />
@if (Model.Tips != null)
{
    @await Html.PartialAsync("_AdminToDoList", Model.Tips)
}
<div class="row">
    <div class="col-4">
        <a asp-controller="Race"
           asp-action="Create"
           class="btn btn-outline-primary btn-sm">@localizer["New Race"]</a>
    </div>
    @if (Model.IsClubAdmin)
    {
        <div class="col-4">
            <a asp-controller="Admin"
               asp-action="Edit"
