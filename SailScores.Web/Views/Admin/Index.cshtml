            </div>
        </div>
    }
</div>

    </main>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        // $(function () {
        //     $('[data-bs-toggle="popover"]').popover()
        // })

        const tooltipTriggerList = document.querySelectorAll('[data-bs-toggle="tooltip"]')
        const tooltipList = [...tooltipTriggerList].map(tooltipTriggerEl => new bootstrap.Tooltip(tooltipTriggerEl))

        var popoverTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="popover"]'))
        var popoverList = popoverTriggerList.map(function (popoverTriggerEl) {
          return new bootstrap.Popover(popoverTriggerEl)
        })

        // Prevent accordion help icons from triggering collapse
        document.querySelectorAll('.accordion-help-icon').forEach(icon => {
            icon.addEventListener('click', function(e) {
                e.stopPropagation();
            });
        });

        // Accordion navigation: expand clicked section and collapse others
        document.querySelectorAll('.accordion-nav').forEach(link => {
            link.addEventListener('click', function(e) {
                e.preventDefault();
                const targetId = this.getAttribute('href').substring(1);
                const targetCollapse = document.getElementById(targetId);

                if (targetCollapse) {
                    // Use Bootstrap's collapse API to show this section
                    const bsCollapse = new bootstrap.Collapse(targetCollapse, { toggle: false });
                    bsCollapse.show();

                    // Scroll to the accordion header (the h2 that precedes the collapse div)
                    setTimeout(() => {
                        const accordionHeader = targetCollapse.previousElementSibling;
                        if (accordionHeader && accordionHeader.classList.contains('accordion-header')) {
                            accordionHeader.scrollIntoView({ behavior: 'smooth', block: 'start' });
                        } else {
                            // Fallback: scroll to the collapse div if header not found
                            targetCollapse.scrollIntoView({ behavior: 'smooth', block: 'start' });
                        }
                    }, 300);
                }
            });
        });

        // Handle hash navigation (e.g., page loaded with #collapseSeries)
        window.addEventListener('hashchange', expandSectionFromHash);
        document.addEventListener('DOMContentLoaded', expandSectionFromHash);

        function expandSectionFromHash() {
            const hash = window.location.hash.substring(1);
            if (hash) {
                const element = document.getElementById(hash);
                if (element && element.classList.contains('accordion-collapse')) {
                    const bsCollapse = new bootstrap.Collapse(element, { toggle: false });
                    bsCollapse.show();
                }
            }
        }
    </script>
}
