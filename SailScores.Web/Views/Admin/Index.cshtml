                    </h4>
                </button>
            </h2>
            <div id="collapseFleets" class="accordion-collapse collapse @(isSetupComplete ? "" : "show")">
                <div class="accordion-body">
                    @await Html.PartialAsync("_FleetList", Model.Fleets)
                </div>
            </div>
        </div>

        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button @(isSetupComplete ? "collapsed" : "")" type="button" data-bs-toggle="collapse" data-bs-target="#collapseSeasons" aria-expanded="@(isSetupComplete ? "false" : "true")" aria-controls="collapseSeasons">
                    <h4 class="mb-0">
