                </div>
            </div>
        </div>
    }

    <div class="accordion-item">
        <h2 class="accordion-header">
            <button class="accordion-button @(isSetupComplete ? "collapsed" : "")" type="button" data-bs-toggle="collapse" data-bs-target="#collapseCompetitors" aria-expanded="@(isSetupComplete ? "false" : "true")" aria-controls="collapseCompetitors">
