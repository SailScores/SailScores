        </div>
    }
    <div class="col-4">
        <a asp-controller="Reports"
           asp-action="Index"
           class="btn btn-outline-primary btn-sm">@localizer["Reports"]</a>
    </div>
    </div>
<div class="row d-none d-md-inline">
    <div class="row">
        <div class="col-4 col-md-auto">
            <span class="fst-italic">Default Scoring</span>
        </div>
        <div class="col-8 col-md-9">
            @Model.DefaultScoringSystemName
        </div>
    </div>
    <div class="row">
        <div class="col-4 col-md-3"></div>
        <div class="col-8 col-md-9">
            @if (Model.IsHidden)
            {
                <span class="text-warning">Not listed on SailScores front page.</span>
            }
        </div>
    </div>
</div>


@{
    bool isSetupComplete = Model.Tips == null || (Model.Tips != null && Model.Tips.Count == 0);
}



