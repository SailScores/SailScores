                <div class="accordion-body">
                    @await Html.PartialAsync("_SeasonList", Model.Seasons)
                </div>
            </div>
        </div>
    }

    @if (Model.CanEditSeries)
    {
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button @(isSetupComplete ? "collapsed" : "")" type="button" data-bs-toggle="collapse" data-bs-target="#collapseSeries" aria-expanded="@(isSetupComplete ? "false" : "true")" aria-controls="collapseSeries">
                    <h4 class="mb-0">
                        <span class="accordion-title">Series</span><a class="accordion-help-icon"
