@model IEnumerable<SailScores.Web.Models.SailScores.UserViewModel>
<div id="usersdiv">
    <div class="row">
        <div class="col-2 col-sm-4">
            <a class="btn btn-primary"
                asp-action="Add"
                asp-controller="User">
                <span class="fas fa-plus"></span>
                <span class="d-none d-sm-inline">
                    New Admin
                </span>
            </a>
        </div>
    </div>
    @foreach (var item in Model.OrderBy(f => f.Name))
    {
        <div class="row border-bottom mt-1 mb-1 pt-1 pb-1 ms-md-2">
            <div class="col-7 col-sm-6 col-md-6 col-lg-4">
                <a class="btn btn-sm btn-outline-danger"
                    asp-action="Delete"
                    asp-controller="User"
                    asp-route-id="@item.Id"
                    title="Delete">
                    <span class="fas fa-trash"></span>
                </a> &nbsp;
                <a class="btn btn-sm btn-outline-primary"
                    asp-action="Edit"
                    asp-controller="User"
                    asp-route-id="@item.Id"
                    title="Edit">
                    <span class="fas fa-pen"></span>
                </a> &nbsp;
                <span class="text-truncate">@Html.DisplayFor(modelItem => item.Name)</span>
            </div>
            <div class="col-5 col-sm-6 col-md-4 col-lg-3">
                <span class="text-truncate d-inline-block w-100">@Html.DisplayFor(modelItem => item.EmailAddress)</span>
            </div>
            <div class="col-6 col-md-2">
                @(!item.Registered ? "Not" : "") Registered
            </div>
            <div class="col-6 col-lg-3 ms-auto ms-lg-0 text-end text-lg-start">
                @switch (item.PermissionLevel)
                {
                    case SailScores.Database.Entities.PermissionLevel.ClubAdministrator:
                        <small class="text-muted">Club Admin</small>
                        break;
                    case SailScores.Database.Entities.PermissionLevel.SeriesScorekeeper:
                        <small class="text-muted">Series Scorekeeper</small>
                        break;
                    case SailScores.Database.Entities.PermissionLevel.RaceScorekeeper:
                        <small class="text-muted">Race Scorekeeper</small>
                        break;
                }
            </div>
        </div>
    }
</div>
