@model SailScores.Web.Models.SailScores.CreateHandicapSystemViewModel

@{
    ViewData["Title"] = "Create Handicap System";
    Layout = "~/Views/Shared/_ClubLayout.cshtml";
}

<h4>Create Handicap System</h4>
<hr />
<div class="row">
    <div class="col-md-8 col-lg-6">
        <form asp-action="Create">
            <input type="hidden" asp-for="ClubId" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" autocomplete="off" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ParentSystemId" class="form-label"></label>
                <select asp-for="ParentSystemId" class="form-select">
                    @foreach (var option in Model.BaseSystemOptions ?? Enumerable.Empty<SailScores.Web.Models.SailScores.HandicapSystemSummary>())
                    {
                        <option value="@option.Id">@option.Name</option>
                    }
                </select>
                <span asp-validation-for="ParentSystemId" class="text-danger"></span>
                <div class="small text-muted mt-1">
                    Select the base formula to inherit. This club system will appear in series handicap selections.
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <input type="submit" value="Create" class="btn btn-primary" />
                <a asp-controller="Admin" asp-action="Index" asp-fragment="handicapsystems"
                   class="btn btn-outline-primary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
