<div class="modal fade" id="editAltSailNumberModal" tabindex="-1" role="dialog" aria-labelledby="editAltSailNumberLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editAltSailNumberLabel">Edit Alternative Sail Number</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input id="altSailNumberCompetitorId" type="hidden" />
                <div class="mb-2">
                    <label class="form-label mb-0">Competitor</label>
                    <div id="altSailNumberCompetitorName" class="form-control-plaintext fw-semibold"></div>
                </div>
                <div class="mb-2">
                    <label class="form-label mb-0">Sail Number</label>
                    <div id="altSailNumberSailNumber" class="form-control-plaintext"></div>
                </div>
                <div class="mb-2">
                    <label class="form-label" for="altSailNumberInput">Alternative Sail Number</label>
                    <input id="altSailNumberInput" type="text" class="form-control" maxlength="20" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button id="altSailNumberSaveButton" type="button" class="btn btn-primary">Save</button>
            </div>
        </div>
    </div>
</div>
