  // ─────────────────────────────────────────────────────────────────────────
  // External Authentication Providers
  //
  // Leave ClientId/AppId empty to disable a provider entirely.
  // Store real credentials in User Secrets (local dev) or Azure App Service
  // Application Settings / Key Vault (staging + production).
  //
  // How to add secrets locally (runs once per provider):
  //   dotnet user-secrets set "Authentication:Google:ClientId"     "<value>"  --project SailScores.Web
  //   dotnet user-secrets set "Authentication:Google:ClientSecret" "<value>"  --project SailScores.Web
  //   (repeat for Microsoft, Apple, Facebook)
  // ─────────────────────────────────────────────────────────────────────────
  "Authentication": {
    // ── Google ──────────────────────────────────────────────────────────────
    // Register at: https://console.cloud.google.com/apis/credentials
    // 1. Create an OAuth 2.0 Client ID (Web application).
    // 2. Add Authorised redirect URIs for each environment:
    //    Local:      https://localhost:5001/signin-google
    //    Staging:    https://stage.sailscores.com/signin-google
    //    Production: https://www.sailscores.com/signin-google
    // 3. Enable the "Google People API" so profile claims are returned.
    "Google": {
      "ClientId": "",
      "ClientSecret": ""
    },

    // ── Microsoft (personal accounts / Entra ID) ────────────────────────────
    // Register at: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
    // 1. New registration → "Accounts in any organizational directory and
    //    personal Microsoft accounts" (or "personal only" for MSA).
    // 2. Add redirect URIs:
    //    Local:      https://localhost:5001/signin-microsoft
    //    Staging:    https://stage.sailscores.com/signin-microsoft
    //    Production: https://www.sailscores.com/signin-microsoft
    // 3. Generate a Client Secret under "Certificates & secrets".
    "Microsoft": {
      "ClientId": "",
      "ClientSecret": ""
    },

    // ── Apple (Sign in with Apple) ──────────────────────────────────────────
    // Register at: https://developer.apple.com/account/resources/identifiers
    // 1. Create an App ID with "Sign in with Apple" capability.
    // 2. Create a Services ID (this becomes ClientId, e.g. com.sailscores.auth).
    //    Add return URLs:
    //    Staging:    https://stage.sailscores.com/signin-apple
    //    Production: https://www.sailscores.com/signin-apple
    //    NOTE: Apple does NOT allow localhost – use ngrok or a staging URL.
    // 3. Create a Sign In with Apple private key (.p8) under "Keys".
    //    Store the full PEM content (including header/footer lines) in PrivateKey.
    //    For user secrets, encode the whole .p8 file content as a single-line string.
    // 4. Domain verification: upload the file from Apple at
    //    https://<yourdomain>/.well-known/apple-developer-domain-association.txt
    //    (the .well-known folder is already served by the app).
    "Apple": {
      "ClientId": "",
      "TeamId": "",
      "KeyId": "",
      "PrivateKey": ""
    },

    // ── Facebook ─────────────────────────────────────────────────────────────
    // Register at: https://developers.facebook.com/apps
    // 1. Add the "Facebook Login" product to your app.
    // 2. Under Facebook Login → Settings add Valid OAuth redirect URIs:
    //    Local:      https://localhost:5001/signin-facebook
    //    Staging:    https://stage.sailscores.com/signin-facebook
    //    Production: https://www.sailscores.com/signin-facebook
    // 3. Request the "email" and "public_profile" permissions.
    // 4. The app must be set to "Live" mode to allow non-test-user logins.
    "Facebook": {
      "AppId": "",
      "AppSecret": ""
    }
  }
